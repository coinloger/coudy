{
	"name": "@coudycode/ui",
	"version": "0.1.0",
	"description": "UI-двигун: React-компоненти для рендерингу агентних взаємодойдій (повідомлення, стрімінг, tool-call'и, дифи, код, thinking)",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./src/index.tsx",
			"import": "./src/index.tsx",
			"default": "./dist/index.js"
		},
		"./styles.css": {
			"import": "./src/styles.css",
			"default": "./dist/styles.css"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"clean": "shx rm -rf dist",
		"build": "tsgo -p tsconfig.build.json",
		"prepublishOnly": "npm run clean && npm run build"
	},
	"peerDependencies": {
		"react": "^18.0.0 || ^19.0.0",
		"react-dom": "^18.0.0 || ^19.0.0"
	},
	"dependencies": {
		"@coudycode/agent-core": "*",
		"@coudycode/ai": "*",
		"lucide-react": "^0.439.0",
		"react-markdown": "^9.0.1",
		"react-syntax-highlighter": "^15.6.1",
		"remark-gfm": "^4.0.1"
	},
	"keywords": [
		"ai",
		"agent",
		"ui",
		"react",
		"render",
		"coudycode"
	],
	"author": "coudycode",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/coinloger/coudy.git",
		"directory": "packages/ui"
	},
	"engines": {
		"node": ">=22.19.0"
	},
	"devDependencies": {
		"@types/react": "^18.3.3",
		"@types/react-dom": "^18.3.0",
		"@types/react-syntax-highlighter": "^15.5.13",
		"@typescript/native-preview": "7.0.0-dev.20260120.1"
	}
}
