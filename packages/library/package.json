{
	"name": "@coudycode/library",
	"version": "0.1.0",
	"description": "Self-growing глобальна бібліотека функцій: store + embeddings-пошук + контекст виконання",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"clean": "shx rm -rf dist",
		"build": "tsgo -p tsconfig.build.json",
		"prepublishOnly": "npm run clean && npm run build"
	},
	"dependencies": {
		"@xenova/transformers": "^2.17.2"
	},
	"keywords": [
		"library",
		"skills",
		"embeddings",
		"semantic-search",
		"coudycode"
	],
	"author": "coudycode",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/coinloger/coudy.git",
		"directory": "packages/library"
	},
	"engines": {
		"node": ">=22.19.0"
	},
	"devDependencies": {
		"@types/node": "24.12.4",
		"shx": "0.3.4",
		"typescript": "^5.5.0",
		"@typescript/native-preview": "7.0.0-dev.20260120.1"
	}
}
